# ─── Database (MySQL) ────────────────────────────────────────────────────────
DATABASE_URL="mysql://root:password@localhost:3306/repairkl_db"

# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Create DB first: mysql -u root -p -e "CREATE DATABASE repairkl_db CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://repairkl.com"
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="RepairKL"
NEXT_PUBLIC_CONTACT_PHONE="+601127272745"
NEXT_PUBLIC_CONTACT_EMAIL="hello@repairkl.com"

