# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/shifty_db?schema=public"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── SMS (Bangladesh) ────────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""
# SMS_PROVIDER="twilio"  # or "bdtel", "sslcommerz"

# ─── Storage ─────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_STORAGE_URL="https://your-minio-or-s3-bucket"
# STORAGE_BUCKET="shifty-assets"
