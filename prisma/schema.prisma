generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  WORKER
  SUPPORT
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum OtpType {
  PHONE_VERIFY
  EMAIL_VERIFY
  PASSWORD_RESET
  LOGIN
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  WORKER_ASSIGNED
  SERVICE_STARTED
  SERVICE_COMPLETED
  PAYMENT_RECEIVED
  REVIEW_REMINDER
  PROMOTION
  SUPPORT_REPLY
  SYSTEM
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Users ──────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  fullName        String
  email           String    @unique
  phone           String    @unique
  passwordHash    String
  avatarUrl       String?
  isEmailVerified Boolean   @default(false)
  isPhoneVerified Boolean   @default(false)
  isActive        Boolean   @default(true)
  role            UserRole  @default(CUSTOMER)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  address         UserAddress?
  otpCodes        OtpCode[]
  bookings        Booking[]          @relation("CustomerBookings")
  reviews         Review[]
  notifications   Notification[]
  savedServices   SavedService[]
  tickets         SupportTicket[]    @relation("CustomerTickets")
  assignedTickets SupportTicket[]    @relation("AgentTickets")
  ticketMessages  TicketMessage[]
  workerProfile   Worker?

  @@map("users")
}

model UserAddress {
  id      String  @id @default(cuid())
  userId  String  @unique
  street  String
  city    String
  state   String
  zipCode String
  country String  @default("BD")
  lat     Float?
  lng     Float?
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_addresses")
}

model OtpCode {
  id        String    @id @default(cuid())
  userId    String
  code      String
  type      OtpType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_codes")
}

// ─── Workers ───────────────────────────────────────────────────────────────────

model Worker {
  id          String          @id @default(cuid())
  userId      String          @unique
  speciality  String
  bio         String?
  rating      Float           @default(0)
  reviewCount Int             @default(0)
  isAvailable Boolean         @default(true)
  isVerified  Boolean         @default(false)
  hourlyRate  Decimal         @db.Decimal(10, 2) @default(0)
  experience  Int             @default(0)
  totalJobs   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments BookingWorker[]
  reviews     Review[]
  earnings    WorkerEarning[]
  schedule    WorkerSchedule[]

  @@map("workers")
}

model WorkerSchedule {
  id        String   @id @default(cuid())
  workerId  String
  dayOfWeek Int      // 0=Sun, 6=Sat
  startTime String   // "08:00"
  endTime   String   // "18:00"
  isOff     Boolean  @default(false)
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerId, dayOfWeek])
  @@map("worker_schedules")
}

model WorkerEarning {
  id        String   @id @default(cuid())
  workerId  String
  bookingId String
  amount    Decimal  @db.Decimal(10, 2)
  paidAt    DateTime?
  createdAt DateTime @default(now())
  worker    Worker   @relation(fields: [workerId], references: [id])

  @@map("worker_earnings")
}

// ─── Service Categories ────────────────────────────────────────────────────────

model ServiceCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  iconUrl     String?
  color       String    @default("#FD6B22")
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  services    Service[]

  @@map("service_categories")
}

model Service {
  id          String          @id @default(cuid())
  categoryId  String
  name        String
  slug        String          @unique
  description String?
  longDesc    String?
  basePrice   Decimal         @default(0) @db.Decimal(10, 2)
  priceUnit   String          @default("fixed")
  imageUrl    String?
  rating      Float           @default(0)
  reviewCount Int             @default(0)
  isActive    Boolean         @default(true)
  isFeatured  Boolean         @default(false)
  duration    Int?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  category    ServiceCategory @relation(fields: [categoryId], references: [id])
  packages    ServicePackage[]
  bookings    Booking[]
  reviews     Review[]
  savedBy     SavedService[]

  @@map("services")
}

model ServicePackage {
  id          String   @id @default(cuid())
  serviceId   String
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  includes    String[]
  isPopular   Boolean  @default(false)
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("service_packages")
}

// ─── Bookings ──────────────────────────────────────────────────────────────────

model Booking {
  id            String        @id @default(cuid())
  bookingCode   String        @unique
  customerId    String
  serviceId     String
  status        BookingStatus @default(PENDING)
  scheduledDate DateTime
  scheduledTime String
  address       String
  notes         String?
  subtotal      Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount     Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount   Decimal       @db.Decimal(10, 2)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod String?
  cancelReason  String?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  customer      User            @relation("CustomerBookings", fields: [customerId], references: [id])
  service       Service         @relation(fields: [serviceId], references: [id])
  workers       BookingWorker[]
  details       BookingDetail?
  payment       Payment?
  review        Review?

  @@map("bookings")
}

model BookingDetail {
  id           String   @id @default(cuid())
  bookingId    String   @unique
  houseSize    String?
  furnitures   Json?
  packedBoxes  Int      @default(0)
  workers      Int      @default(1)
  electricians Int      @default(0)
  extraNotes   String?
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_details")
}

model BookingWorker {
  id         String   @id @default(cuid())
  bookingId  String
  workerId   String
  assignedAt DateTime @default(now())
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  worker     Worker   @relation(fields: [workerId], references: [id])

  @@unique([bookingId, workerId])
  @@map("booking_workers")
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String        @unique
  amount        Decimal       @db.Decimal(10, 2)
  method        String
  status        PaymentStatus @default(PENDING)
  transactionId String?       @unique
  gateway       String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Review {
  id         String   @id @default(cuid())
  customerId String
  serviceId  String
  workerId   String?
  bookingId  String   @unique
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  customer   User     @relation(fields: [customerId], references: [id])
  service    Service  @relation(fields: [serviceId], references: [id])
  worker     Worker?  @relation(fields: [workerId], references: [id])
  booking    Booking  @relation(fields: [bookingId], references: [id])

  @@map("reviews")
}

// ─── Support ───────────────────────────────────────────────────────────────────

model SupportTicket {
  id          String         @id @default(cuid())
  customerId  String
  agentId     String?
  bookingId   String?
  subject     String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  category    String?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  customer    User            @relation("CustomerTickets", fields: [customerId], references: [id])
  agent       User?           @relation("AgentTickets", fields: [agentId], references: [id])
  messages    TicketMessage[]

  @@map("support_tickets")
}

model TicketMessage {
  id        String        @id @default(cuid())
  ticketId  String
  senderId  String
  message   String
  isInternal Boolean      @default(false)
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    User          @relation(fields: [senderId], references: [id])

  @@map("ticket_messages")
}

// ─── Notifications & Promotions ────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  body      String
  type      NotificationType
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model SavedService {
  id        String   @id @default(cuid())
  userId    String
  serviceId String
  savedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@map("saved_services")
}

model Promotion {
  id            String   @id @default(cuid())
  code          String   @unique
  title         String
  description   String?
  discountType  String
  discountValue Decimal  @db.Decimal(10, 2)
  minOrderValue Decimal  @default(0) @db.Decimal(10, 2)
  maxDiscount   Decimal? @db.Decimal(10, 2)
  usageLimit    Int?
  usedCount     Int      @default(0)
  validFrom     DateTime
  validUntil    DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@map("promotions")
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String
  linkUrl   String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("banners")
}
